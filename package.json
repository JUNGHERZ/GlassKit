{
  "name": "@jungherz-de/glasskit",
  "version": "1.3.2",
  "description": "A modern glassmorphism CSS component library – inspired by iOS 26 Liquid Glass. 22 components, dark & light mode, no dependencies.",
  "main": "glasskit.css",
  "style": "glasskit.css",
  "files": [
    "glasskit.css",
    "glasskit.min.css",
    "glasskit-styles.js",
    "theme-override.css",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "minify": "cleancss -O2 --source-map -o glasskit.min.css glasskit.css",
    "build:styles-js": "node build-styles-js.mjs",
    "build": "npm run minify && npm run build:styles-js"
  },
  "keywords": [
    "css",
    "glassmorphism",
    "liquid-glass",
    "ios26",
    "visionos",
    "ui",
    "components",
    "design-tokens",
    "dark-mode",
    "light-mode",
    "no-dependencies"
  ],
  "author": "Jungherz GmbH <info@jungherz.com> (https://www.jungherz.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JUNGHERZ/GlassKit.git"
  },
  "homepage": "https://github.com/JUNGHERZ/GlassKit",
  "bugs": {
    "url": "https://github.com/JUNGHERZ/GlassKit/issues"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3"
  }
}
